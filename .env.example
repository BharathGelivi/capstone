# X-RAG Diagnostic Framework Environment Config

# API Keys
# GROQ_API_KEY is the default LLM provider (configs/models.py LLM_PROVIDER =
# "groq") -- free tier, get one at https://console.groq.com/keys.
GROQ_API_KEY=gsk_your_groq_key_here
# HF_TOKEN is only needed if you switch LLM_PROVIDER back to "huggingface"
# (e.g. once HF Inference Providers credits are purchased/renewed).
HF_TOKEN=hf_your_token_here

# Telemetry / Other Settings
ALLOW_TELEMETRY=False
