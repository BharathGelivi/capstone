            "trace_id": "a91db66c-64cc-42f3-8144-cc1c066ca1bf",
            "claim_text": "Generally, murder requires intent to cause death.",
            "source_sentence": "",
            "sentence_id": "S004",
            "claim_index": 3,
            "character_start": 407,
            "character_end": 456,
            "normalized_text": null,
            "claim_type": null,
