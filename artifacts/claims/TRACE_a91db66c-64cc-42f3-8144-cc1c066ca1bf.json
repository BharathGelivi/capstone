            "trace_id": "a91db66c-64cc-42f3-8144-cc1c066ca1bf",
            "claim_text": "If someone causes death without intent, it may be classified as culpable homicide not amounting to murder (Section 304).",
            "source_sentence": "",
            "sentence_id": "S005",
            "claim_index": 4,
            "character_start": 456,
            "character_end": 576,
