    "claims": [
        {
            "claim_id": "2385202c-f539-4844-a507-6a6a63529e39_C001",
            "trace_id": "2385202c-f539-4844-a507-6a6a63529e39",
            "claim_text": "The sections that punish murder are 110 and 111.",
            "source_sentence": "",
            "sentence_id": "S001",
            "claim_index": 0,
            "character_start": 0,
            "character_end": 48,
            "normalized_text": null,
            "claim_type": null,
            "verification_complexity": null,
            "claim_hash": null,
            "metadata": {}
        },
        {
            "claim_id": "2385202c-f539-4844-a507-6a6a63529e39_C002",
            "trace_id": "2385202c-f539-4844-a507-6a6a63529e39",
            "claim_text": "Section 110 states that whoever does any act with the intention or knowledge that would make them guilty of culpable homicide not amounting to murder, shall be punished.",
            "source_sentence": "",
            "sentence_id": "S002",
            "claim_index": 1,
            "character_start": 91,
            "character_end": 260,
            "normalized_text": null,
            "claim_type": null,
            "verification_complexity": null,
            "claim_hash": null,
            "metadata": {}
        },
        {
            "claim_id": "2385202c-f539-4844-a507-6a6a63529e39_C003",
            "trace_id": "2385202c-f539-4844-a507-6a6a63529e39",
            "claim_text": "If hurt is caused, the punishment is increased.",
            "source_sentence": "",
            "sentence_id": "S003",
            "claim_index": 2,
            "character_start": 261,
            "character_end": 308,
            "normalized_text": null,
            "claim_type": null,
            "verification_complexity": null,
            "claim_hash": null,
            "metadata": {}
        },
        {
            "claim_id": "2385202c-f539-4844-a507-6a6a63529e39_C004",
            "trace_id": "2385202c-f539-4844-a507-6a6a63529e39",
            "claim_text": "Section 111 covers the abetment of such acts.",
            "source_sentence": "",
            "sentence_id": "S004",
            "claim_index": 3,
            "character_start": 309,
            "character_end": 354,
            "normalized_text": null,
            "claim_type": null,
            "verification_complexity": null,
            "claim_hash": null,
            "metadata": {}
        },
        {
            "claim_id": "2385202c-f539-4844-a507-6a6a63529e39_C005",
            "trace_id": "2385202c-f539-4844-a507-6a6a63529e39",
            "claim_text": "Murder without intent refers to situations where the act committed would normally result in culpable homicide not amounting to murder, but without the specific intent to kill.",
            "source_sentence": "",
            "sentence_id": "S005",
            "claim_index": 4,
            "character_start": 391,
            "character_end": 566,
            "normalized_text": null,
            "claim_type": null,
            "verification_complexity": null,
            "claim_hash": null,
            "metadata": {}
        },
        {
            "claim_id": "2385202c-f539-4844-a507-6a6a63529e39_C006",
            "trace_id": "2385202c-f539-4844-a507-6a6a63529e39",
            "claim_text": "Illustration (a) of Section 110 describes a situation where A fires a pistol at Z under provocation that would make A guilty of culpable homicide not amounting to murder if death resulted, but A does not have the specific intent to kill.",
            "source_sentence": "",
            "sentence_id": "S006",
            "claim_index": 5,
            "character_start": 621,
            "character_end": 858,
            "normalized_text": null,
            "claim_type": null,
            "verification_complexity": null,
            "claim_hash": null,
            "metadata": {}
        },
        {
            "claim_id": "2385202c-f539-4844-a507-6a6a63529e39_C007",
            "trace_id": "2385202c-f539-4844-a507-6a6a63529e39",
            "claim_text": "In such cases, the act still constitutes murder due to the circumstances and intent, even if death was not the specific aim.",
            "source_sentence": "",
            "sentence_id": "S007",
            "claim_index": 6,
            "character_start": 789,
            "character_end": 913,
            "normalized_text": null,
            "claim_type": null,
            "verification_complexity": null,
            "claim_hash": null,
            "metadata": {}
        }
