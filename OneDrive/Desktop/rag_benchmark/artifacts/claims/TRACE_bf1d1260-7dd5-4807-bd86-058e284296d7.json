            "trace_id": "bf1d1260-7dd5-4807-bd86-058e284296d7",
            "claim_text": "To murder without intent means to cause death without having the specific intention to kill.",
            "source_sentence": "",
            "sentence_id": "S004",
            "claim_index": 3,
            "character_start": 342,
            "character_end": 434,
            "normalized_text": null,
