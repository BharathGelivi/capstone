            "trace_id": "bf1d1260-7dd5-4807-bd86-058e284296d7",
            "claim_text": "In Illustration (b) of the context, A fires a pistol at Y under grave and sudden provocation, not intending or knowing that Z, who is near but out of sight, might be killed.",
            "source_sentence": "",
            "sentence_id": "S005",
            "claim_index": 4,
            "character_start": 459,
            "character_end": 632,
            "normalized_text": null,
            "claim_type": null,
            "verification_complexity": null,
